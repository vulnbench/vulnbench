      "difficulty_tier": "tier_1",
      "ecosystem": "maven",
      "model_patch": "--- a/src/main/java/net/sf/mpxj/common/InputStreamHelper.java\n+++ b/src/main/java/net/sf/mpxj/common/InputStreamHelper.java\n@@ -23,6 +23,7 @@\n \n package net.sf.mpxj.common;\n \n+import java.io.File;\n import java.io.IOException;\n import java.io.InputStream;\n import java.nio.file.Files;\n@@ -56,7 +57,7 @@\n       {\n          while ((zipEntry = zip.getNextEntry()) != null)\n          {\n-            Path file = dir.resolve(zipEntry.getName());\n+            Path file = zipSlipProtect(zipEntry, dir);\n             if (zipEntry.isDirectory())\n             {\n                if (Files.notExists(file))\n@@ -78,4 +79,22 @@\n \n       return dir;\n    }\n+\n+   /**\n+    * Protect against zip slip vulnerability by ensuring the resolved path\n+    * remains within the target directory.\n+    *\n+    * @param zipEntry zip entry to validate\n+    * @param targetDir target directory\n+    * @return validated path\n+    * @throws IOException if the path is outside the target directory\n+    */\n+   private static Path zipSlipProtect(ZipEntry zipEntry, Path targetDir) throws IOException\n+   {\n+      Path targetDirResolved = targetDir.resolve(zipEntry.getName());\n+      Path normalizePath = targetDirResolved.normalize();\n+      if (!normalizePath.startsWith(targetDir.normalize()))\n+      {\n+         throw new IOException(\"Bad zip entry: \" + zipEntry.getName());\n+      }\n+      return normalizePath;\n+   }\n }",
      "generation_time_s": 15.082,
      "patch_analysis": {
        "judge_score": 0.5,
        "judge_reasoning": "The candidate patch addresses zip slip protection using Path.normalize() instead of getCanonicalPath(), which is a valid approach. However, it modifies a different method/code path than the gold patch. The gold patch fixes the `processZipStream(File dir, InputStream inputStream)` method (around line 174), while the candidate patch modifies what appears to be a different method that uses `Path` objects instead of `File` objects. The vulnerable code in `processZipStream` that uses `File.getCanonicalPath()` with the incomplete string prefix check (`startsWith(canonicalDestinationDirPath + File.separator)`) is not addressed by the candidate patch. The candidate only fixes a Path-based method, leaving the original vulnerable File-based method unfixed.",
        "judge_verdict": "fail"
      },
